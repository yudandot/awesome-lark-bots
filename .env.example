# ═══════════════════════════════════════════════════════════════
# AIlarkteams 环境变量配置
# ═══════════════════════════════════════════════════════════════
#
# 使用方法：
#   1. 复制本文件：cp .env.example .env
#   2. 编辑 .env，把 xxx 替换为你的真实值
#   3. 带 # 号的行是注释/可选项，去掉 # 号即可启用
#
# ═══════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────┐
# │  第一层：必填（3 个变量就能跑起来）                           │
# └─────────────────────────────────────────────────────────────┘

# 飞书应用凭证（飞书开放平台 → 创建应用 → 凭证与基础信息）
# 详细步骤见 docs/FEISHU_QUICKSTART.md
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# DeepSeek（所有机器人的主力大模型）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx


# ┌─────────────────────────────────────────────────────────────┐
# │  第二层：按需选填（看你要用哪个 bot）                         │
# └─────────────────────────────────────────────────────────────┘

# ─── 脑暴机器人需要（两个额外的大模型） ──────────────────────
# 豆包（创意角色「核桃仁」）— https://console.volcengine.com
DOUBAO_API_KEY=xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxx                              # 替换为你的端点 ID

# Kimi（素材角色 + 最终交付）— https://platform.moonshot.cn
KIMI_API_KEY=xxx

# ─── 舆情监控机器人需要 ──────────────────────────────────────
# JustOneAPI（社交平台数据采集）
JOA_TOKEN=your_justoneapi_token
# JOA_BASE_URL=http://your-joa-server:30015  # JOA 服务地址（找管理员获取）

# ─── 飞书 Webhook（推荐，用于实时推送讨论过程到群） ──────────
# 获取：飞书群 → 设置 → 群机器人 → 添加「自定义机器人」→ 复制地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ─── 联网搜索（推荐，免费 1000 次/月） ──────────────────────
# 不配也能用（自动降级到 DuckDuckGo）
# 申请地址：https://tavily.com（用 GitHub 登录即可）
# TAVILY_API_KEY=tvly-xxx


# ┌─────────────────────────────────────────────────────────────┐
# │  第三层：高级配置（按模块分区）                               │
# └─────────────────────────────────────────────────────────────┘

# ─── 多 Bot 专用飞书凭证 ─────────────────────────────────────
# 同时跑多个 bot 时，每个 bot 需要不同的 App ID（否则会同时收到消息）
# 未配专用凭证的 bot 会自动复用上面的 FEISHU_APP_ID
# 详见 docs/FEISHU_APP_IDS.md

# PLANNER_FEISHU_APP_ID=cli_xxx
# PLANNER_FEISHU_APP_SECRET=xxx
# ASSISTANT_FEISHU_APP_ID=cli_xxx
# ASSISTANT_FEISHU_APP_SECRET=xxx
# CREATIVE_FEISHU_APP_ID=cli_xxx
# CREATIVE_FEISHU_APP_SECRET=xxx
SENTIMENT_FEISHU_APP_ID=cli_xxx
SENTIMENT_FEISHU_APP_SECRET=xxx
CONDUCTOR_FEISHU_APP_ID=                # 建议与脑暴用不同应用
CONDUCTOR_FEISHU_APP_SECRET=

# ─── 脑暴 Webhook 分群 ──────────────────────────────────────
# BRAINSTORM_FEISHU_WEBHOOK=             # 脑暴专用群（不设则用 FEISHU_WEBHOOK）
# FEISHU_SECRET=                         # Webhook 签名密钥（可选）
# PLANNER_FEISHU_WEBHOOK=                # 规划专用群
# CONDUCTOR_BRAINSTORM_WEBHOOK=          # 自媒体助手调用脑暴时，讨论推送到此群

# ─── 大模型微调 ─────────────────────────────────────────────
# DEEPSEEK_BASE_URL=https://api.deepseek.com    # 默认值，通常不需要改
# DEEPSEEK_MODEL=deepseek-chat                  # 默认模型
# KIMI_BASE_URL=https://api.moonshot.cn/v1       # 默认值
# KIMI_MODEL=moonshot-v1-128k                    # 默认模型

# Gemini（可选 —— 可一键替换脑暴全部角色）
# 申请地址：https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash

# 脑暴角色可插拔切换
# BRAINSTORM_PROVIDER=gemini              # 一键让所有角色用同一 provider
# ROLE_PROVIDER_芝麻仁=gemini             # 按角色精细覆盖（优先级最高）
# ROLE_PROVIDER_核桃仁=doubao             # 可混搭

# ─── 助手机器人：日历 ───────────────────────────────────────
# 操作用户个人日历需要用户授权的 token（不需要日历功能可跳过）
# FEISHU_CALENDAR_ID=                    # 指定日历 ID（不填则自动获取主日历）
# FEISHU_TOKEN_CALENDAR_CREATE=          # 用户 token：往日历加日程
# FEISHU_TOKEN_CALENDAR_GET=             # 用户 token：查看日程

# Google 日历（可选，助手可同时聚合飞书和 Google 日历）
# GOOGLE_CALENDAR_ICAL_URL=              # iCal 订阅地址（最简单）
# GOOGLE_CALENDAR_CREDENTIALS_JSON=      # 或用服务账号 JSON 路径

# ─── 助手机器人：定时推送 ───────────────────────────────────
# FEISHU_PUSH_OPEN_ID=                   # 每日简报接收人的 open_id
                                          # 不配则推送给最近和机器人聊过天的人

# ─── 舆情监控：GitHub 云存储 ────────────────────────────────
# 采集结果上传到 GitHub 仓库，方便 AI 工具直接调用
# GITHUB_TOKEN=ghp_xxx                   # Personal Access Token（需 repo 权限）
# GITHUB_REPO=user/sentiment-data        # 格式: owner/repo

# ─── 自媒体助手：人设与策略 ─────────────────────────────────
# 也可在飞书里用「人设」「目标受众」「内容目标」命令设置
# CONDUCTOR_PERSONA_FILE=               # 人设文件路径，如：data/conductor/personas/帮你打工bot.md
# CONDUCTOR_PERSONA=                     # 或直接写人设文案（与 PERSONA_FILE 二选一）
# CONDUCTOR_TARGET_AUDIENCE=            # 目标受众，如：18-30岁一二线女性
# CONDUCTOR_CONTENT_GOALS=              # 内容目标，如：涨粉、种草、品牌曝光
# CONDUCTOR_ALWAYS_USE_BRAINSTORM=false # true=所有选题先脑暴再创作
# CONDUCTOR_ASK_MODE_FOR_TOPIC=1       # 1=提选题后让用户选模式（0=直接执行）
# CONDUCTOR_DEFAULT_BRAND=              # 仅定时任务使用

# ─── 自媒体助手：定时选题+生成 ──────────────────────────────
# CONDUCTOR_SCHEDULE_ENABLED=false      # 启用后每日定时扫描热点、生成内容
# CONDUCTOR_SCHEDULE_SCAN_TIMES=08:00,12:00,19:00   # 执行时间点
# CONDUCTOR_MAX_POSTS_PER_DAY=3         # 每日发布上限
# CONDUCTOR_SCHEDULE_TOPIC_KEYWORDS=    # 选题关键词（逗号分隔）
# CONDUCTOR_SCHEDULE_BRAND=             # 定时任务使用的品牌
# CONDUCTOR_SCHEDULE_PLATFORMS=xiaohongshu   # 目标平台（逗号分隔）
# CONDUCTOR_NOTIFY_WEBHOOK=             # 有待审批内容时通知的飞书群
# CONDUCTOR_AUTO_PUBLISH=true           # false=只存草稿，等审批后再发
# CONDUCTOR_CRON_TOKEN=                 # 电脑休眠时用（见 conductor/SCHEDULE_WHEN_SLEEP.md）
# CONDUCTOR_SENSITIVE_WORDS=            # 敏感词过滤（逗号分隔）

# ─── 自媒体助手：Seedance / Seedream 素材生成 ───────────────
# 视频/图片生成通过火山方舟 Ark SDK，和豆包用同一套 API Key
# 已配 DOUBAO_API_KEY 则无需额外设置
# ARK_API_KEY=                          # 单独的 Ark API Key（可选）
# ARK_IMAGE_MODEL=seedream-3-0          # 图片生成模型
# ARK_VIDEO_MODEL=doubao-seedance-1-0-pro-250528  # 视频生成模型

# ─── 自媒体助手：自动发布（浏览器自动化） ───────────────────
# 用 Playwright 控制 Chrome 自动登录平台并发布
# CHROME_CDP_URL=http://localhost:9222   # Chrome 调试端口（手动启动 Chrome 后连接）
# CHROME_USER_DATA=                      # Chrome 用户数据目录路径
#   macOS 默认：~/Library/Application Support/Google/Chrome
#   Linux 默认：~/.config/google-chrome
#   Windows 默认：%LOCALAPPDATA%\Google\Chrome\User Data

# ─── 飞书云文档 & 多维表格 ──────────────────────────────────
# 规划机器人文档交付、助手项目管理、素材需求管理
# 使用应用的 tenant_access_token（自动获取），需在飞书开放平台开通权限：
#   - docx:document（创建/编辑文档）
#   - sheets:spreadsheet（创建/编辑电子表格）
#   - bitable:app（创建/编辑多维表格）
#   - drive:drive:permission:member（分享文档给用户）
# 如未开通 sheets 权限，表格型文档会自动降级为云文档

# FEISHU_TOKEN_DOC_CREATE=               # 可选：手动指定 token（不填则自动用 tenant_access_token）
# FEISHU_DOC_OWNER_OPEN_ID=              # 创建文档后自动授予编辑权限的用户 open_id
# FEISHU_DOC_BASE_URL=                   # 飞书文档域名（默认 open.feishu.cn）

# ─── 其他 ────────────────────────────────────────────────────
# PORT=8080                              # PaaS 健康检查端口（Docker 部署时用）
# MEMO_STORE_PATH=                       # 备忘存储路径（默认 data/memos.json）
# LLM_REQUEST_TIMEOUT=120                # LLM 单次请求超时秒数（默认 120）
