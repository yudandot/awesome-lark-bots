# ═══════════════════════════════════════════════════════════════
# AIlarkteams 环境变量配置
# ═══════════════════════════════════════════════════════════════
#
# 使用方法：
#   1. 复制本文件：cp .env.example .env
#   2. 编辑 .env，把 xxx 替换为你的真实值
#   3. 带 # 号的行是注释/可选项，去掉 # 号即可启用
#
# 最低配置（只需 3 个变量就能跑起来）：
#   FEISHU_APP_ID + FEISHU_APP_SECRET + DEEPSEEK_API_KEY
#
# ═══════════════════════════════════════════════════════════════

# ─── 飞书应用凭证 ───────────────────────────────────────────
# 在飞书开放平台创建应用后获取：https://open.feishu.cn
# 五个机器人可以共用一套凭证，也可以各自独立应用。

# 主凭证（脑暴机器人使用，其他机器人未单独配置时也用这个）
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 规划机器人（不配则复用上面的主凭证）
# PLANNER_FEISHU_APP_ID=cli_xxx
# PLANNER_FEISHU_APP_SECRET=xxx

# 助手机器人（不配则复用主凭证）
# ASSISTANT_FEISHU_APP_ID=cli_xxx
# ASSISTANT_FEISHU_APP_SECRET=xxx

# 创意 Prompt 机器人（不配则复用主凭证）
# CREATIVE_FEISHU_APP_ID=cli_xxx
# CREATIVE_FEISHU_APP_SECRET=xxx

# 舆情监控机器人（不配则复用主凭证）
SENTIMENT_FEISHU_APP_ID=cli_xxx
SENTIMENT_FEISHU_APP_SECRET=xxx

# ─── 飞书 Webhook ──────────────────────────────────────────
# 脑暴分群：脑暴机器人发起的脑暴用 FEISHU_WEBHOOK，自媒体助手发起的脑暴用 CONDUCTOR_BRAINSTORM_WEBHOOK（见下方指挥官区块）
# 获取方式：飞书群 → 设置 → 群机器人 → 添加「自定义机器人」→ 复制 Webhook 地址
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# BRAINSTORM_FEISHU_WEBHOOK=             # 脑暴机器人专用群（不设则用 FEISHU_WEBHOOK）
# FEISHU_SECRET=                         # Webhook 签名密钥（可选）
# PLANNER_FEISHU_WEBHOOK=                # 规划专用群（不配则复用 FEISHU_WEBHOOK）

# ─── 大模型 API Keys ──────────────────────────────────────
# 三家大模型分工：DeepSeek=主力, 豆包=创意, Kimi=长文本

# DeepSeek（必须 —— 所有机器人都用）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com    # 默认值，通常不需要改
# DEEPSEEK_MODEL=deepseek-chat                  # 默认模型

# 豆包（脑暴机器人必须 —— 用于创意角色「核桃仁」）
# 申请地址：https://console.volcengine.com
DOUBAO_API_KEY=xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxx                              # 替换为你的端点 ID

# Kimi（脑暴机器人必须 —— 用于素材角色和最终交付）
# 申请地址：https://platform.moonshot.cn
KIMI_API_KEY=xxx
# KIMI_BASE_URL=https://api.moonshot.cn/v1       # 默认值
# KIMI_MODEL=moonshot-v1-128k                    # 默认模型

# ─── 日历相关（助手机器人使用） ─────────────────────────────
# 操作用户个人日历需要用户授权的 token。
# 如果不需要日历功能，可以跳过这部分。

# FEISHU_CALENDAR_ID=                    # 指定日历 ID（可选，不填则自动获取主日历）
# FEISHU_TOKEN_CALENDAR_CREATE=          # 用户 token：往日历加日程（需 OAuth 授权获取）
# FEISHU_TOKEN_CALENDAR_GET=             # 用户 token：查看日程

# Google 日历（可选 —— 助手可以同时聚合飞书和 Google 日历）
# GOOGLE_CALENDAR_ICAL_URL=              # iCal 订阅地址（推荐，最简单）
# GOOGLE_CALENDAR_CREDENTIALS_JSON=      # 或用服务账号 JSON 路径

# ─── 定时推送（助手机器人使用） ─────────────────────────────
# FEISHU_PUSH_OPEN_ID=                   # 每日简报接收人的 open_id
                                          # 不配则自动推送给最近和机器人聊过天的人

# ─── 舆情监控相关 ──────────────────────────────────────────

# JustOneAPI（社交平台数据采集 —— 舆情机器人必须）
JOA_TOKEN=your_justoneapi_token
# JOA_BASE_URL=http://your-joa-server:30015  # JOA 服务地址（找管理员获取）

# GitHub 云存储（可选 —— 采集结果上传到 GitHub 仓库，方便 Claude Code 等 AI 工具直接调用）
# GITHUB_TOKEN=ghp_xxx                   # Personal Access Token（需 repo 权限）
# GITHUB_REPO=user/sentiment-data        # 格式: owner/repo

# ─── 自媒体助手机器人（自媒体全流程编排） ─────────────────────
# 飞书交互必填：在飞书开放平台创建应用，拿到 App ID / App Secret 填下面两项。
# 详细步骤见 conductor/FEISHU_SETUP.md
# 注意：若脑暴已用 FEISHU_APP_ID，请务必为自媒体助手单独建一个应用并填下面两项，
#       否则同一应用会连上脑暴+自媒体助手两个进程，打开会话时会收到两张欢迎卡（可能先看到自媒体助手的）。
CONDUCTOR_FEISHU_APP_ID=                # 飞书应用 App ID（如 cli_xxx，建议与脑暴用不同应用）
CONDUCTOR_FEISHU_APP_SECRET=            # 飞书应用 App Secret
# 若不填上面两项，会自动复用上面的 FEISHU_APP_ID / FEISHU_APP_SECRET（仅适合只跑自媒体助手不跑脑暴时）

# 发帖人设与目标（可选，也可在飞书里用「人设」「目标受众」「内容目标」命令设置）
# CONDUCTOR_PERSONA_FILE=               # 人设文件路径（相对项目根），如：data/conductor/personas/帮你打工bot.md
# CONDUCTOR_PERSONA=                     # 或直接写人设文案（与 CONDUCTOR_PERSONA_FILE 二选一）
# CONDUCTOR_TARGET_AUDIENCE=            # 目标受众，如：18-30岁一二线女性
# CONDUCTOR_CONTENT_GOALS=              # 内容目标，如：涨粉、种草、品牌曝光
# CONDUCTOR_ALWAYS_USE_BRAINSTORM=false # true=接到选题后先调用脑暴+规划再创作（仅在不选模式时生效）
# CONDUCTOR_ASK_MODE_FOR_TOPIC=1       # 1=提选题后让用户选「脑暴/快速」（0=直接按默认或 ALWAYS_USE_BRAINSTORM 执行）
# CONDUCTOR_DEFAULT_BRAND=              # 仅定时任务等使用；会话内不设默认品牌，脑暴按话题自动判断，用户可发「品牌 xxx」指定
# CONDUCTOR_BRAINSTORM_WEBHOOK=         # 自媒体助手调用脑暴时，讨论过程推送到此群（不设则用 FEISHU_WEBHOOK）

# 定时选题+生成+发布（CONDUCTOR_SCHEDULE_ENABLED=true 时生效）
# CONDUCTOR_SCHEDULE_ENABLED=false      # 启用后每日定时扫描热点、生成内容
# CONDUCTOR_SCHEDULE_SCAN_TIMES=08:00,12:00,19:00   # 每天在这几个时间点各执行一次选题+生成（默认 08:00）
# CONDUCTOR_MAX_POSTS_PER_DAY=3         # 每日发布上限
# CONDUCTOR_SCHEDULE_TOPIC_KEYWORDS=    # 选题关键词（逗号分隔），从热点中优先匹配
# CONDUCTOR_SCHEDULE_BRAND=             # 定时任务使用的品牌（留空则用 CONDUCTOR_DEFAULT_BRAND）
# CONDUCTOR_SCHEDULE_PLATFORMS=xiaohongshu   # 定时任务目标平台（逗号分隔）
# CONDUCTOR_NOTIFY_WEBHOOK=             # 定时生成后通知的飞书群 Webhook（有待审批内容时推送）
# CONDUCTOR_AUTO_PUBLISH=true           # 默认直接发布；设为 false 则只存草稿、等飞书审批后再发
# CONDUCTOR_CRON_TOKEN=                 # 电脑休眠时用：cron_server 的触发 token，供外部 cron 调 /cron?token=xxx（见 conductor/SCHEDULE_WHEN_SLEEP.md）
# CONDUCTOR_SENSITIVE_WORDS=            # 敏感词过滤（逗号分隔）

# ─── Seedance / Seedream 素材生成（自媒体助手使用）─────────────────
# 视频/图片生成通过火山方舟 Ark SDK 调用，和豆包用同一套 API Key。
# 如果已配置 DOUBAO_API_KEY 则无需额外设置，会自动复用。
# 如需单独的 Key：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# ARK_API_KEY=                          # 单独的 Ark API Key（可选，不配则用 DOUBAO_API_KEY）
# ARK_IMAGE_MODEL=seedream-3-0          # 图片生成模型（默认 seedream-3-0）
# ARK_VIDEO_MODEL=doubao-seedance-1-0-pro-250528  # 视频生成模型

# ─── 自动发布（Playwright 浏览器自动化） ─────────────────────
# CHROME_CDP_URL=http://localhost:9222   # Chrome 调试端口（手动启动 Chrome 后连接）
# CHROME_USER_DATA=                      # Chrome 用户数据目录（自动启动浏览器时用）

# ─── 飞书云文档（规划机器人文档交付使用） ────────────────────
# 规划完成后可一键生成飞书云文档（Brief / 内容日历 / 时间线 / 决策备忘）。
# 文档创建使用应用的 tenant_access_token（自动获取），需在飞书开放平台开通：
#   - docx:document（创建/编辑文档）
#   - drive:drive:permission:member（分享文档给指定用户）

# FEISHU_TOKEN_DOC_CREATE=               # 可选：手动指定 token（不填则自动用 tenant_access_token）
# FEISHU_DOC_OWNER_OPEN_ID=              # 创建文档后自动授予编辑权限的用户 open_id
# FEISHU_DOC_BASE_URL=                   # 飞书文档域名（默认 open.feishu.cn，企业自建可改）

# ─── 联网研究助手（Research Bot） ──────────────────────────
# Tavily 搜索 API（推荐 —— 免费 1000 次/月，效果好于 DuckDuckGo）
# 申请地址：https://tavily.com（用 GitHub 登录即可）
# 不配也能用（自动降级到 DuckDuckGo 免费搜索）
# TAVILY_API_KEY=tvly-xxx

# ─── 其他 ──────────────────────────────────────────────────
# PORT=8080                              # PaaS 健康检查端口（Docker 部署时用）
# MEMO_STORE_PATH=                       # 备忘存储路径（默认 data/memos.json）
# LLM_REQUEST_TIMEOUT=120                # LLM 单次请求超时秒数（默认 120）
